DATABASE_URL=postgresql://postgres:Pass1234@localhost/dtcy
JWT_SECRET=your_super_secret_production_key_here
SECRET_KEY=another_secret_key_for_security
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOW_PUBLIC_REGISTRATION=false

# SMTP email configuration used when an admin creates members.
# Gmail example: use an App Password, not your normal Gmail password.
MAIL_ENABLED=true
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_app_password
MAIL_FROM=your_email@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Digital Tech-Connect Yearbook
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
USE_CREDENTIALS=true
VALIDATE_CERTS=true
